{
	"name": "expo-build-disk-cache",
	"description": "Cache Expo iOS and Android native builds on local disk to skip repeated compilations.",
	"version": "0.7.4",
	"author": {
		"name": "WookieFPV (Lukas Müller)",
		"url": "https://github.com/WookieFPV"
	},
	"license": "MIT",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"files": [
		"/dist"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/WookieFPV/expo-build-disk-cache"
	},
	"homepage": "https://github.com/WookieFPV/expo-build-disk-cache#readme",
	"bugs": {
		"url": "https://github.com/WookieFPV/expo-build-disk-cache/issues"
	},
	"keywords": [
		"expo",
		"react-native",
		"build-cache",
		"ios",
		"android",
		"prebuild"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsup",
		"build:dev": "tsup --watch --clean false",
		"changeset": "changeset",
		"test": "bun test",
		"lint": "bunx biome check --fix",
		"lint:CI": "bunx biome check",
		"release": "changeset publish",
		"typecheck": "tsc",
		"version-packages": "changeset version",
		"prepublishOnly": "bun run typecheck && bun run lint:CI && bun test && bun run build"
	},
	"dependencies": {
		"cosmiconfig": "^9.0.0",
		"env-paths": "^2.2.1",
		"zod": "^4.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.0",
		"@changesets/cli": "2.31.0",
		"@total-typescript/ts-reset": "0.6.1",
		"@tsconfig/bun": "1.0.10",
		"@types/bun": "1.3.14",
		"lefthook": "2.1.9",
		"tsup": "8.5.1",
		"typescript": "6.0.3",
		"@expo/cli": "56.1.16",
		"@expo/config": "56.0.9"
	},
	"peerDependencies": {
		"@expo/cli": "*",
		"@expo/config": "*"
	},
	"engines": {
		"node": ">=18.0.0"
	}
}
