{
	"name": "expo-build-disk-cache",
	"description": "A plugin for Expo CLI that provides disk-based app build caching",
	"version": "0.7.2",
	"author": {
		"name": "WookieFPV (Lukas Müller)",
		"url": "github.com/WookieFPV"
	},
	"license": "MIT",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"files": [
		"/dist"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/WookieFPV/expo-build-disk-cache"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsup",
		"build:dev": "tsup --watch --clean false",
		"changeset": "changeset",
		"test": "bun test",
		"lint": "bunx biome check --fix",
		"lint:CI": "bunx biome check",
		"release": "changeset publish",
		"typecheck": "tsc",
		"version-packages": "changeset version",
		"prepublishOnly": "bun run typecheck && bun run lint:CI && bun test && bun run build"
	},
	"dependencies": {
		"cosmiconfig": "^9.0.0",
		"env-paths": "^2.2.1",
		"zod": "^4.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.6",
		"@changesets/cli": "2.30.0",
		"@total-typescript/ts-reset": "0.6.1",
		"@tsconfig/bun": "1.0.10",
		"@types/bun": "1.3.10",
		"lefthook": "2.1.3",
		"tsup": "8.5.1",
		"typescript": "5.9.3",
		"@expo/cli": "^55.0.16",
		"@expo/config": "^12.0.9"
	},
	"peerDependencies": {
		"@expo/cli": "*",
		"@expo/config": "*"
	},
	"engines": {
		"node": ">=18.0.0"
	}
}
